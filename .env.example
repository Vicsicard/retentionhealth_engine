# Cloudflare Account Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git

# Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare API Token (for Wrangler authentication)
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_api_token_here

# Worker Secrets (set via: wrangler secret put SECRET_NAME)
# These are NOT stored in .env, but documented here for reference
# AUTH_SECRET=your_jwt_signing_secret_here
# ADMIN_KEY=your_admin_key_here

# D1 Database Configuration
# DATABASE_ID is in wrangler.toml after creation
# DATABASE_NAME=retentionhealth_v1
